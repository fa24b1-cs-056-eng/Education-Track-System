#include <Servo.h>
#include <Keypad.h>
#include <Password.h>
#define buzzer 11
#define servoPin 10
Servo servo;
Password password = Password("1234");
const byte ROWS = 4;
const byte COLS = 4;
char keys[ROWS][COLS] = {
{'D', 'C', 'B', 'A'},
{'#', '9', '6', '3'},
{'0', '8', '5', '2'},
{'*', '7', '4', '1'}
};
byte rowPins[ROWS] = {2, 3, 4, 5}; // Connect to keypad row pins
byte colPins[COLS] = {6, 7, 8, 9}; // Connect to keypad column pins
Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);
byte maxPasswordLength = 4;
byte currentPasswordLength = 0;
bool doorIsLocked = true;
void setup() {
Serial.begin(9600);
pinMode(buzzer, OUTPUT);
servo.attach(servoPin);
lockDoor(); // Start with locked door
Serial.println("PASSWORD DOOR LOCK SYSTEM (Serial Monitor Output)");
Serial.println("Enter 4-digit password using keypad:");
}
void loop() {
char key = keypad.getKey();
if (key != NO_KEY) {
if (key == 'C') {
resetInput();
Serial.println("\nPassword entry cleared.");
}
else if (isDigit(key)) {
Serial.print("*");
password.append(key);
currentPasswordLength++;
if (currentPasswordLength == maxPasswordLength) {
if (password.evaluate()) {
Serial.println("\nCorrect Password!");
if (doorIsLocked) {
unlockDoor();
} else {
lockDoor();
}
} else {
Serial.println("\nWrong Password!");
buzzError();
}
resetInput();
}
}
      }
}

void resetInput() {
password.reset();
currentPasswordLength = 0;
}
void lockDoor() {
servo.write(110); // Adjust angle as per lock position
digitalWrite(buzzer, HIGH);
delay(300);
digitalWrite(buzzer, LOW);
Serial.println("DOOR LOCKED.");
doorIsLocked = true;
}
void unlockDoor() {
servo.write(50);
digitalWrite(buzzer, HIGH);
delay(300);
digitalWrite(buzzer, LOW);
Serial.println("DOOR UNLOCKED.");
doorIsLocked = false;
}
void buzzError() {
for (int i = 0; i < 2; i++) {
digitalWrite(buzzer, HIGH);
delay(150);
digitalWrite(buzzer, LOW);
delay(150);
}
}

